doctype html
html
  head
    title= title
    meta(name="viewport" content="width=device-width, initial-scale=1")
    link(rel="stylesheet" href="/css/style.css")
  body
    h1 Pets
    a(href="/update-pet") + Add New Pet
    .cards
      each pet in data
        .card
          h2.card__name #{pet.properties.pet_name}
          p.card__type Type: #{pet.properties.pet_type}
          a(href=`/update-pet?id=${pet.id}`) Edit
